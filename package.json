{
  "name": "reddtoric.github.io",
  "version": "0.1.0",
  "private": true,
  "dependencies": {
    "@fontsource/open-sans": "^4.2.2",
    "@fontsource/roboto-mono": "^4.2.2",
    "@material-ui/core": "^4.11.4",
    "@mdi/js": "^5.9.55",
    "@mdi/react": "^1.5.0",
    "@testing-library/jest-dom": "^4.2.4",
    "@testing-library/react": "^9.5.0",
    "@testing-library/user-event": "^7.2.1",
    "axios": "^0.21.1",
    "gh-pages": "^3.1.0",
    "react": "^16.14.0",
    "react-dom": "^16.14.0",
    "react-scripts": "^4.0.3",
    "styled-components": "^5.2.3"
  },
  "scripts": {
    "start": "react-scripts start",
    "build": "react-scripts build",
    "format": "watch \"npm run format-eslint\" src",
    "format-eslint": "eslint src --fix",
    "dev": "concurrently \"npm run start\" \"npm run format\"",
    "pub": "npm run build && gh-pages -d build"
  },
  "scriptsDescriptionsAndArchive": {
    "start": "Start react app",
    "build": "Build react app",
    "format": "Watch changes while developing and format",
    "format-eslint": "Formatting with eslint",
    "dev": "Developing with web browser and watch changes",
    "pub": "Publish",
    "_": "----- Archive below -----",
    "deploy": "npm run build && gh-pages -d build",
    "test": "react-scripts test",
    "format-prettier": "prettier --write \"**/*.+(js|jsx|json|css|md)\""
  },
  "eslintConfig": {
    "extends": "react-app"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "homepage": "https://eddevs.com",
  "devDependencies": {
    "concurrently": "^6.0.2",
    "eslint": "^7.25.0",
    "eslint-config-google": "^0.14.0",
    "eslint-config-prettier": "^8.3.0",
    "eslint-plugin-import": "^2.22.1",
    "eslint-plugin-prettier": "^3.4.0",
    "eslint-plugin-react": "^7.23.2",
    "eslint-plugin-simple-import-sort": "^7.0.0",
    "prettier": "^2.2.1",
    "watch": "^1.0.2"
  }
}
